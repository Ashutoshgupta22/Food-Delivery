<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
    android:paddingStart="2dp"
    android:paddingTop="16dp"
    android:paddingEnd="8dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/card_item_specials"
            style="@style/Widget.Material3.CardView.Filled"
            android:layout_width="180dp"
            android:layout_height="300dp"
            android:layout_marginTop="10dp"
            android:layout_marginStart="26dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="42dp"
            android:clickable="true"
            app:cardElevation="2dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tv_specials_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="150dp"
                    android:text="Noodles"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_specials_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_specials_name"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="6dp"
                    android:text="Rs 300"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/tv_specials_about"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_specials_price"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:layout_marginEnd="16dp"
                    android:text="Rice noodles with shrimp, eggs, and spicy mexican sauce" />

            </RelativeLayout>


        </androidx.cardview.widget.CardView>


        <ImageView
            android:id="@+id/img_specials"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginStart="6dp"
            android:layout_marginTop="2dp"
            android:outlineProvider="background"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:background="@drawable/circular_bg"
            android:elevation="12dp"
            tools:layout_editor_absoluteX="49dp"
            tools:layout_editor_absoluteY="115dp"
            tools:srcCompat="@tools:sample/avatars" />


    </RelativeLayout>
